{
  "name": "@push-to/node-source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "test": "bun test",
    "typecheck": "nx run-many -t typecheck",
    "typecheck:spec": "tsc --noEmit -p packages/node/tsconfig.spec.json",
    "readme-check": "tsc --noEmit -p tools/readme-check/tsconfig.json",
    "type-contract-check": "tsc --noEmit -p tools/type-contract-check/tsconfig.json"
  },
  "private": true,
  "devDependencies": {
    "@nx/js": "22.2.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.13.21",
    "@swc/helpers": "~0.5.17",
    "@types/node": "^24.10.4",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "nx": "22.2.3",
    "prettier": "^3.7.4",
    "semantic-release": "^25.0.2",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3"
  }
}
