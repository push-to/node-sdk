{
  "name": "@push-to/node",
  "version": "1.0.0",
  "description": "PushTo server-side admin SDK for Node.js — typed 1:1 wrapper over the PushTo v2 REST surface.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/push-to/node-sdk.git",
    "directory": "packages/node"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^24.10.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
